{
    "name": "2pi/swarm-relay",
    "description": "KrillNotes Relay — lightweight store-and-forward sync service",
    "license": "MPL-2.0",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-sodium": "*",
        "ext-pdo_sqlite": "*",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "paragonie/sodium_compat": "^1.21"
    },
    "autoload": {
        "psr-4": {
            "Relay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Relay\\Tests\\": "tests/"
        }
    }
}
